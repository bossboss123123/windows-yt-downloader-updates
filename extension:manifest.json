{
  "manifest_version": 3,
  "name": "YT Downloader",
  "version": "4.0.3",
  "description": "下載 YouTube 影片和音訊",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://youtu.be/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}